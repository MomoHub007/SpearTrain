-- ลูปการทำงานเบื้องหลัง (ระบบอัจฉริยะ)
-- =========================================================
local CurrentTrainTarget = nil 

task.spawn(function()
    while task.wait() do
        -- [ กรณีเปิดพร้อมกันทั้ง 2 อย่าง ] : Train -> Stop -> จำเงิน -> Throw -> รอเงินเด้ง -> รอ 1 วิ
        if MoMoConfig.AutoTrain and MoMoConfig.AutoThrow then
            local bestTarget = getBestTarget()
            
            if bestTarget then pcall(function() trainRemote:FireServer(bestTarget) end) end
            
            local waitTime = MoMoConfig.TrainDuration or 10
            local elapsed = 0
            while elapsed < waitTime and MoMoConfig.AutoTrain and MoMoConfig.AutoThrow do
                task.wait(0.1)
                elapsed = elapsed + 0.1
            end
            
            if not (MoMoConfig.AutoTrain and MoMoConfig.AutoThrow) then continue end
            
            pcall(function() stopTrainRemote:FireServer() end)
            task.wait(0.2) 
            
            local oldCash = 0
            local cashStat = player:WaitForChild("leaderstats"):WaitForChild("Cash")
            if cashStat then oldCash = cashStat.Value end
            
            if MoMoConfig.ThrowZone then 
                pcall(function() throwRemote:FireServer(MoMoConfig.ThrowZone) end) 
            end
            
            if cashStat then
                local timeout = 0
                while MoMoConfig.AutoTrain and MoMoConfig.AutoThrow and timeout < 15 do 
                    task.wait(0.1)
                    timeout = timeout + 0.1
                    if cashStat.Value > oldCash then
                        task.wait(1) 
                        break 
                    end
                end
            end

        -- [ กรณีเปิดแค่ Auto Train อย่างเดียว ]
        elseif MoMoConfig.AutoTrain and not MoMoConfig.AutoThrow then
            local bestTarget = getBestTarget()
            if bestTarget then 
                if CurrentTrainTarget ~= bestTarget then
                    pcall(function() stopTrainRemote:FireServer() end)
                    task.wait(0.2)
                    pcall(function() trainRemote:FireServer(bestTarget) end) 
                    CurrentTrainTarget = bestTarget
                else
                    pcall(function() trainRemote:FireServer(bestTarget) end)
                end
            end
            task.wait(0.5) 

        -- [ กรณีเปิดแค่ Auto Throw อย่างเดียว ]
        elseif MoMoConfig.AutoThrow and not MoMoConfig.AutoTrain then
            if MoMoConfig.ThrowZone then 
                pcall(function() throwRemote:FireServer(MoMoConfig.ThrowZone) end) 
            end
            task.wait(0.1)
        end
    end
end)

