local function clearSpecificNotifs()
    pcall(function()
        local notifsPath = playerGui:FindFirstChild("MainUI") and playerGui.MainUI:FindFirstChild("Notifs")
        if notifsPath then notifsPath:ClearAllChildren() end
    end)
end
clearSpecificNotifs()

local function handleNotifs(UI)
    pcall(function()
        if UI:IsA("TextLabel") or UI:IsA("TextBox") then
            local text = string.lower(UI.Text)
            if string.find(text, "don't have enough") or string.find(text, "not enough") then
                local current = UI
                for i = 1, 3 do
                    if current.Parent and (current.Parent:IsA("Frame") or current.Parent:IsA("ImageLabel") or current.Parent:IsA("CanvasGroup")) then
                        current = current.Parent
                    else break end
                end
                current:Destroy()
            end
        end
        if UI.Parent and UI.Parent.Name == "Notifs" then
            task.wait(0.05)
            UI:Destroy()
        end
    end)
end
playerGui.DescendantAdded:Connect(handleNotifs)

-- ==========================================
-- ฟังก์ชันหาเป้าหมายการฝึกที่ดีที่สุด
-- ==========================================
local function getBestTarget()
    local leaderstats = player:FindFirstChild("leaderstats")
    if not leaderstats or not leaderstats:FindFirstChild("Power") then return nil end
    local currentPower = leaderstats.Power.Value
    local bestName, highestReq = nil, -1
    
    for _, target in pairs(Workspace.Targets:GetChildren()) do
        local req = target:GetAttribute("Required")
        local zone = target:GetAttribute("Zone")
        if req and type(req) == "number" and zone == MoMoConfig.TrainZone then
            if currentPower >= req and req > highestReq then
                highestReq = req
                bestName = target.Name
            end
        end
    end
    return bestName
end

